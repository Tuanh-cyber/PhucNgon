# Sao chép file này thành .env và điền giá trị thực
# .env đã được .gitignore chặn — KHÔNG commit .env thật

DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/phucngon_dev

# SECRET_KEY dùng để ký JWT token.
# SECRET_KEY thật KHÔNG được commit lên Git, mỗi môi trường (dev/prod) phải có giá trị RIÊNG.
# Sinh chuỗi ngẫu nhiên đủ dài: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Hạn dùng JWT access token, tính bằng PHÚT. 129600 = 90 ngày — vì app cho người lớn tuổi,
# ưu tiên ít phải đăng nhập lại. Nếu cần bảo mật cao hơn (refresh token), cân nhắc lại thiết
# kế này sau, hiện tại chọn đơn giản theo đúng yêu cầu UX.
ACCESS_TOKEN_EXPIRE_MINUTES=129600

APP_ENV=development

# Thư mục GỐC chứa file tĩnh bài tập (ảnh + audio). Bên trong phải có 4 thư mục con:
#   Picture/{Topic}/{vocab_id}.jpg        (ảnh từ vựng, topic folder: Activity/Body/Family/
#                                          Food&Drink/Number/Object)
#   command_audio_wav/{command_id}.wav    (audio câu hỏi bài Nghe và đoán, vd C001.wav)
#   sentence_instance_wav/{si_id}.wav     (audio câu mẫu bài Hoàn thành câu, vd SI001.wav)
#   Vocab/{vocab_id}.wav                  (audio phát âm mẫu từ vựng, vd VFA1001.wav)
# Mặc định (không set): thư mục CHA của repo backend. Thư mục thiếu -> server vẫn chạy,
# chỉ log warning và ảnh/audio loại đó trả 404.
# STATIC_ASSETS_BASE_DIR=/duong/dan/toi/thu-muc-assets

# ASR (Module 2 - Vy, PhoWhisper).
# Đổi ASR_MODE thành 'real' KHI VÀ CHỈ KHI Vy đã finetune xong và service ASR đang chạy —
# trước đó luôn giữ 'fake' để kết quả test không bị nhiễu bởi 1 model ASR chưa hoàn thiện.
ASR_MODE=fake
ASR_SERVICE_URL=http://127.0.0.1:8001/asr
